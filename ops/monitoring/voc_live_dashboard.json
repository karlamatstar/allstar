{
  "title": "VOC 실시간 운영",
  "uid": "voc-live-operations",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "tags": ["voc", "live", "operations"],
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "프로필별 VOC 요청 처리량",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}, "overrides": []},
      "targets": [{"expr": "sum(rate(voc_chat_requests_total[1m])) by (profile, status)", "legendFormat": "{{profile}} · {{status}}"}]
    },
    {
      "id": 2,
      "title": "프로필별 p95 처리시간",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}, "overrides": []},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(voc_chat_latency_seconds_bucket[5m])) by (le, profile))", "legendFormat": "{{profile}} p95"}]
    },
    {
      "id": 3,
      "title": "VOC 독립 품질 평가 결과",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}, "overrides": []},
      "targets": [{"expr": "sum(increase(voc_judge_total[30m])) by (profile, status)", "legendFormat": "{{profile}} · {{status}}"}]
    },
    {
      "id": 4,
      "title": "최근 30분 VOC 요청 수",
      "type": "stat",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(increase(voc_chat_requests_total[30m])) or vector(0)", "legendFormat": "전체"}]
    }
  ]
}
