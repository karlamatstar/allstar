{
  "title": "VOC QA A~D 테스트케이스 비교",
  "uid": "voc-qa-abcd",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {"from": "now-24h", "to": "now"},
  "tags": ["voc", "qa", "abcd", "testcase"],
  "templating": {"list": []},
  "panels": [
    {"id": 1, "title": "A~D 최신 평균 점수", "type": "bargauge", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 70}, {"color": "yellow", "value": 80}, {"color": "green", "value": 90}]}}, "overrides": []}, "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}, "targets": [{"expr": "voc_testcase_latest_average_score", "legendFormat": "프로필 {{profile}}", "instant": true}]},
    {"id": 2, "title": "PASS·REVIEW·FAIL·N/A 분포", "type": "bargauge", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "min": 0, "color": {"mode": "palette-classic"}}, "overrides": []}, "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}, "targets": [{"expr": "voc_testcase_latest_case_results", "legendFormat": "{{profile}} · {{result}}", "instant": true}]},
    {"id": 3, "title": "A~D 평균 점수 변화", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 100, "color": {"mode": "palette-classic"}}, "overrides": []}, "targets": [{"expr": "voc_testcase_latest_average_score", "legendFormat": "프로필 {{profile}}"}]},
    {"id": 4, "title": "프로필별 전체·평균 처리시간", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "palette-classic"}}, "overrides": []}, "targets": [{"expr": "voc_testcase_latest_duration_seconds", "legendFormat": "{{profile}} · 전체"}, {"expr": "voc_testcase_latest_case_average_duration_seconds", "legendFormat": "{{profile}} · 케이스 평균"}]},
    {"id": 5, "title": "평가 항목별 평균 달성률", "type": "bargauge", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "palette-classic"}}, "overrides": []}, "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}, "targets": [{"expr": "voc_testcase_latest_criterion_achievement_percent", "legendFormat": "{{profile}} · {{criterion}}", "instant": true}]},
    {"id": 6, "title": "테스트케이스별 최신 점수", "type": "bargauge", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 100, "color": {"mode": "palette-classic"}}, "overrides": []}, "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}, "targets": [{"expr": "voc_testcase_latest_case_score", "legendFormat": "{{profile}} · {{case_id}} · {{result}}", "instant": true}]},
    {"id": 7, "title": "테스트케이스별 처리시간", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "palette-classic"}}, "overrides": []}, "targets": [{"expr": "voc_testcase_latest_case_duration_seconds", "legendFormat": "{{profile}} · {{case_id}}"}]},
    {"id": 8, "title": "최신 보고서 저장 케이스 수", "type": "stat", "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "min": 0, "color": {"mode": "palette-classic"}}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "targets": [{"expr": "voc_testcase_latest_cases_total", "legendFormat": "프로필 {{profile}}", "instant": true}]},
    {"id": 9, "title": "마지막 보고서 갱신 후 경과시간", "type": "stat", "gridPos": {"h": 8, "w": 6, "x": 18, "y": 24}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s", "min": 0, "color": {"mode": "palette-classic"}}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "targets": [{"expr": "time() - voc_testcase_last_report_timestamp_seconds", "legendFormat": "프로필 {{profile}}", "instant": true}]}
  ]
}
