    {"id": 2, "title": "A~D 프로필별 실패 요청", "type": "barchart", "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}, "overrides": []}, "targets": [{"expr": "sum(increase(voc_chat_requests_total{status=\"error\"}[6h])) by (profile)", "legendFormat": "프로필 {{profile}}"}]},
