# 실제 키는 이 파일이 아니라 .env에 입력합니다.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AI Agent
PORTFOLIO_OPENAI_MODEL=gpt-5.6-terra

# VOC 역할별 모델. A~D는 config/model_profiles.py에서 이 값을 조합합니다.
VOC_OPENAI_GENERATION_MODEL=gpt-5.6-luna
VOC_OPENAI_JUDGE_MODEL=gpt-5.6-terra
VOC_ANTHROPIC_GENERATION_MODEL=claude-sonnet-4-6
VOC_ANTHROPIC_JUDGE_MODEL=claude-sonnet-5

VOC_OPENAI_GENERATION_REASONING=none
VOC_OPENAI_JUDGE_REASONING=low
VOC_ANTHROPIC_GENERATION_EFFORT=low
VOC_ANTHROPIC_JUDGE_EFFORT=low
VOC_ANTHROPIC_THINKING=disabled

VOC_API_URL=http://localhost:8100
PORTFOLIO_API_URL=http://localhost:8000
GRAFANA_URL=http://localhost:3000
